# Copy to .env or export these variables before starting the target FastAPI app.
# Use a long random value in real deployments. Example generation:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=replace-with-a-long-random-secret

# Optional: keep auth data outside the repository.
AUTH_USERS_FILE=./runtime/.auth_users.json
AUTH_BOOTSTRAP_SUPERUSERS_FILE=./config/auth/bootstrap_superusers.json

# Optional: token lifetime in seconds. Default is 43200 (12 hours).
AUTH_TOKEN_TTL_SECONDS=43200
